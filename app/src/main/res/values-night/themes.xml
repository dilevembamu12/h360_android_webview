<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.H360POS" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/h360_primary</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/h360_primary</item>
    </style>

    <style name="Theme.H360POS.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/h360_primary</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/h360_primary</item>
        <item name="android:navigationBarColor">@color/h360_primary</item>
    </style>

    <style name="ThemeOverlay.H360POS.ToolbarPopup" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:popupBackground">@color/h360_menu_bg</item>
        <item name="android:textColor">@color/h360_menu_text</item>
    </style>
</resources>
