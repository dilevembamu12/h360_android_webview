<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#111A31">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widgetAdviceTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/insights_advice_default_title"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="15sp" />

        <Button
            android:id="@+id/widgetAdviceRefresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights_refresh"
            android:textAllCaps="false" />
    </LinearLayout>

    <TextView
        android:id="@+id/widgetAdviceMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/insights_advice_default_message"
        android:textColor="#E5EEFF"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widgetAdviceFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#8FD19E"
        android:textSize="11sp" />

    <Button
        android:id="@+id/widgetAdviceOpen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/insights_open_dashboard"
        android:textAllCaps="false" />

</LinearLayout>
